<?xml version="1.0" encoding="utf-8"?>
<!-- Form screen for adding a new task or editing an existing one -->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Task title input — required field -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Task Title *"
            android:textStyle="bold"
            android:textSize="16sp" />

        <EditText
            android:id="@+id/edit_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="e.g. Submit weekly report"
            android:inputType="text"
            android:textColor="#000000"
            android:layout_marginBottom="16dp" />

        <!-- Optional description input -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Description"
            android:textStyle="bold"
            android:textSize="16sp" />

        <EditText
            android:id="@+id/edit_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Optional notes or details"
            android:inputType="textMultiLine"
            android:minLines="3"
            android:gravity="top"
            android:textColor="#000000"
            android:layout_marginBottom="16dp" />

        <!-- Due date input -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Due Date"
            android:textStyle="bold"
            android:textSize="16sp" />

        <EditText
            android:id="@+id/edit_due_date"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="e.g. 2025-05-20"
            android:inputType="text"
            android:textColor="#000000"
            android:layout_marginBottom="16dp" />

        <!-- Checkbox to mark the task as completed -->
        <CheckBox
            android:id="@+id/checkbox_completed_form"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mark as Completed"
            android:textSize="16sp"
            android:layout_marginBottom="24dp" />

        <!-- Save button submits the form and returns to MainActivity -->
        <Button
            android:id="@+id/btn_save"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Save Task"
            android:textSize="18sp" />

    </LinearLayout>
</ScrollView>